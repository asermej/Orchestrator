<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260308120002-add-scoring-weight-to-competency-responses" author="system">
        <comment>Add scoring_weight column to competency_responses to denormalize the competency weight at time of interview scoring.</comment>
        <addColumn tableName="competency_responses">
            <column name="scoring_weight" type="int">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
