<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260306120000-drop-question-packages-competency-key-unique" author="system">
        <comment>Questions are uniquely identified by id (GUID). Allow same label/package_key per competency.</comment>
        <dropUniqueConstraint
            tableName="question_packages"
            constraintName="uk_question_packages_competency_key"/>
    </changeSet>

</databaseChangeLog>
