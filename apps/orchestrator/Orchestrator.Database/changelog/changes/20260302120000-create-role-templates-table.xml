<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260302120000-create-role-templates-table" author="system">
        <createTable tableName="role_templates">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="role_key" type="varchar(100)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_role_templates_role_key"/>
            </column>
            <column name="role_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="industry" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="max_follow_ups_per_question" type="int" defaultValueNumeric="2">
                <constraints nullable="false"/>
            </column>
            <column name="scoring_scale_min" type="int" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="scoring_scale_max" type="int" defaultValueNumeric="5">
                <constraints nullable="false"/>
            </column>
            <column name="flag_threshold" type="int" defaultValueNumeric="2">
                <constraints nullable="false"/>
            </column>
            <!-- Audit fields -->
            <column name="created_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp">
                <constraints nullable="true"/>
            </column>
            <column name="created_by" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
            <column name="updated_by" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
            <column name="is_deleted" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="timestamp">
                <constraints nullable="true"/>
            </column>
            <column name="deleted_by" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex tableName="role_templates" indexName="idx_role_templates_role_key">
            <column name="role_key"/>
        </createIndex>

        <createIndex tableName="role_templates" indexName="idx_role_templates_is_deleted">
            <column name="is_deleted"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
