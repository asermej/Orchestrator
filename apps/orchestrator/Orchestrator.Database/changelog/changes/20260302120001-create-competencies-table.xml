<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260302120001-create-competencies-table" author="system">
        <createTable tableName="competencies">
            <column name="id" type="uuid" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="role_template_id" type="uuid">
                <constraints nullable="false" foreignKeyName="fk_competencies_role_template" references="role_templates(id)"/>
            </column>
            <column name="competency_key" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="default_weight" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="is_required" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="display_order" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <!-- Audit fields -->
            <column name="created_at" type="timestamp" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp">
                <constraints nullable="true"/>
            </column>
            <column name="created_by" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
            <column name="updated_by" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
            <column name="is_deleted" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="timestamp">
                <constraints nullable="true"/>
            </column>
            <column name="deleted_by" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex tableName="competencies" indexName="idx_competencies_role_template_id">
            <column name="role_template_id"/>
        </createIndex>

        <createIndex tableName="competencies" indexName="idx_competencies_is_deleted">
            <column name="is_deleted"/>
        </createIndex>

        <addUniqueConstraint tableName="competencies"
            columnNames="role_template_id, competency_key"
            constraintName="uk_competencies_role_template_key"/>
    </changeSet>

</databaseChangeLog>
