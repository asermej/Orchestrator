<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260307130001-add-dimensions-probed-to-competency-responses" author="system">
        <comment>Which dimensions the AI generated a follow-up for (stored as JSON array of dimension ids/keys).</comment>
        <addColumn tableName="competency_responses">
            <column name="dimensions_probed" type="jsonb">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
