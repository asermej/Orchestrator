<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260308120000-add-agent-behavioral-fields" author="system">
        <comment>Add structured behavioral fields (tone, pace, acknowledgment_style, additional_instructions) to agents. These replace the free-form system_prompt for user-facing configuration.</comment>

        <addColumn tableName="agents">
            <column name="tone" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
            <column name="pace" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
            <column name="acknowledgment_style" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
            <column name="additional_instructions" type="text">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
